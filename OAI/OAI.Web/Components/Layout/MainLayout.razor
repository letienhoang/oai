@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> L
@inject IOptions<ApplicationInfoOptions> ApplicationInfoOptions

<div class="@AppShellClass" style="@SidebarStyle">
    @if (!IsSidebarCollapsed)
    {
        <aside class="app-sidebar text-bg-dark">
            <NavMenu />
        </aside>
    }

    <section class="app-main flex-grow-1 d-flex flex-column min-vh-100">
        <header class="topbar navbar bg-white border-bottom shadow-sm px-4">
            <div class="container-fluid px-0">
                <div class="d-flex align-items-center gap-3">
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary"
                            @onclick="ToggleSidebar">
                        @(IsSidebarCollapsed ? "☰" : "←")
                    </button>

                    <div>
                        <div class="fw-bold fs-5 text-dark">@L["AppName"]</div>
                        <div class="text-secondary small">
                            @L["AppSubtitle"]
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2">
                    @if (!IsSidebarCollapsed)
                    {
                        <div class="btn-group btn-group-sm">
                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    disabled="@(CurrentSidebarSize == SidebarSize.Small)"
                                    @onclick="() => ChangeSidebarSize(SidebarSize.Small)">
                                @L["SidebarSmall"]
                            </button>

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    disabled="@(CurrentSidebarSize == SidebarSize.Normal)"
                                    @onclick="() => ChangeSidebarSize(SidebarSize.Normal)">
                                @L["SidebarNormal"]
                            </button>

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    disabled="@(CurrentSidebarSize == SidebarSize.Large)"
                                    @onclick="() => ChangeSidebarSize(SidebarSize.Large)">
                                @L["SidebarLarge"]
                            </button>
                        </div>
                    }

                    <LanguageSelector/>
                    <AuthMenu />

                    <span class="badge rounded-pill text-bg-primary">@L["EnvironmentDevelopment"]</span>
                </div>
            </div>
        </header>

        <main class="app-content flex-grow-1 p-4">
            @Body
        </main>

        <footer class="app-footer border-top bg-white">
            <div class="px-4 py-3 text-secondary small">
                @ApplicationInfo.Name v@(ApplicationInfo.Version) &middot; Developed by @ApplicationInfo.AuthorName &middot; @ApplicationInfo.Description
            </div>
        </footer>
    </section>
</div>

<ToastContainer />
<TooltipInitializer />
