@inherits LayoutComponentBase

<div class="@AppShellClass" style="@SidebarStyle">
    @if (!IsSidebarCollapsed)
    {
        <aside class="app-sidebar text-bg-dark">
            <NavMenu />
        </aside>
    }

    <section class="app-main flex-grow-1 d-flex flex-column min-vh-100">
        <header class="topbar navbar bg-white border-bottom shadow-sm px-4">
            <div class="container-fluid px-0">
                <div class="d-flex align-items-center gap-3">
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary"
                            @onclick="ToggleSidebar">
                        @(IsSidebarCollapsed ? "☰" : "←")
                    </button>

                    <div>
                        <div class="fw-bold fs-5 text-dark">OAI Invoice Extraction</div>
                        <div class="text-secondary small">
                            OCR, extraction, validation and audit workflow
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2">
                    @if (!IsSidebarCollapsed)
                    {
                        <div class="btn-group btn-group-sm">
                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    disabled="@(CurrentSidebarSize == SidebarSize.Small)"
                                    @onclick="() => ChangeSidebarSize(SidebarSize.Small)">
                                Nhỏ
                            </button>

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    disabled="@(CurrentSidebarSize == SidebarSize.Normal)"
                                    @onclick="() => ChangeSidebarSize(SidebarSize.Normal)">
                                Vừa
                            </button>

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    disabled="@(CurrentSidebarSize == SidebarSize.Large)"
                                    @onclick="() => ChangeSidebarSize(SidebarSize.Large)">
                                Rộng
                            </button>
                        </div>
                    }

                    <span class="badge rounded-pill text-bg-primary">Development</span>
                </div>
            </div>
        </header>

        <main class="app-content flex-grow-1 p-4">
            @Body
        </main>
    </section>
</div>