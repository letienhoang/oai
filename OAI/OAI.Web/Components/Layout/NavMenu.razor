@inject IStringLocalizer<SharedResource> L
@inject IWebHostEnvironment HostEnvironment
<nav class="nav-menu p-3">
    <div class="d-flex align-items-center gap-3 mb-4 p-2">
        <div class="brand-logo rounded-3 bg-primary text-white d-grid place-items-center fw-bold">
            OAI
        </div>

        <div>
            <div class="fw-bold text-white">@L["InvoiceSystem"]</div>
            <div class="small text-secondary">@L["GraduationThesis"]</div>
        </div>
    </div>

    <div class="mb-4">
        <div class="nav-section-title">@L["Overview"]</div>

        <AuthorizeView Policy="@ApplicationPolicies.ViewDashboard">
            <NavLink class="nav-link app-nav-link" href="/" Match="NavLinkMatch.All">
                <span class="nav-icon">📊</span>
                <span>@L["Dashboard"]</span>
            </NavLink>
        </AuthorizeView>
    </div>

    <div class="mb-4">
        <div class="nav-section-title">@L["Invoices"]</div>

        <AuthorizeView Policy="@ApplicationPolicies.UploadInvoices">
            <NavLink class="nav-link app-nav-link" href="/invoices/upload">
                <span class="nav-icon">⬆️</span>
                <span>@L["UploadInvoice"]</span>
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Policy="@ApplicationPolicies.ViewInvoices">
            <NavLink class="nav-link app-nav-link" href="/invoices">
                <span class="nav-icon">🧾</span>
                <span>@L["InvoiceList"]</span>
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Policy="@ApplicationPolicies.ViewValidationIssues">
            <NavLink class="nav-link app-nav-link" href="/invoices/validation">
                <span class="nav-icon">✅</span>
                <span>@L["DataValidation"]</span>
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Policy="@ApplicationPolicies.ViewVendors">
            <NavLink class="nav-link app-nav-link" href="/vendors">
                <span class="nav-icon">🏢</span>
                <span>@L["Vendors"]</span>
            </NavLink>
        </AuthorizeView>
    </div>

    <div>
        <div class="nav-section-title">@L["System"]</div>

        <AuthorizeView Policy="@ApplicationPolicies.ViewAuditLogs">
            <NavLink class="nav-link app-nav-link" href="/audit-logs">
                <span class="nav-icon">🕘</span>
                <span>@L["AuditLogs"]</span>
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Policy="@ApplicationPolicies.ViewSettings">
            <NavLink class="nav-link app-nav-link" href="/settings">
                <span class="nav-icon">⚙️</span>
                <span>@L["Settings"]</span>
            </NavLink>
        </AuthorizeView>

        @if (HostEnvironment.IsDevelopment())
        {
            <AuthorizeView Roles="@ApplicationRoles.Administrator">
                <NavLink class="nav-link app-nav-link" href="/dev-tools/demo-data">
                    <span class="nav-icon">🧪</span>
                    <span>@L["DemoDataToolsTitle"]</span>
                </NavLink>
            </AuthorizeView>
        }
    </div>
</nav>
