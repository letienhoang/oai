@inject IStringLocalizer<SharedResource> L
<nav class="nav-menu p-3">
    <div class="d-flex align-items-center gap-3 mb-4 p-2">
        <div class="brand-logo rounded-3 bg-primary text-white d-grid place-items-center fw-bold">
            OAI
        </div>

        <div>
            <div class="fw-bold text-white">@L["InvoiceSystem"]</div>
            <div class="small text-secondary">@L["GraduationThesis"]</div>
        </div>
    </div>

    <div class="mb-4">
        <div class="nav-section-title">@L["Overview"]</div>

        <NavLink class="nav-link app-nav-link" href="/" Match="NavLinkMatch.All">
