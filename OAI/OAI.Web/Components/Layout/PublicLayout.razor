@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> L

<div class="public-layout min-vh-100 d-flex flex-column">
    <header class="public-header border-bottom bg-white">
        <div class="container d-flex flex-wrap align-items-center justify-content-between gap-3 py-3">
            <div>
                <div class="fw-bold fs-4 text-dark">@L["AppName"]</div>
                <div class="text-secondary small">@L["AppSubtitle"]</div>
            </div>

            <div aria-label="@L["Language"]">
                <LanguageSelector />
            </div>
        </div>
    </header>

    <main class="public-content flex-grow-1">
        <div class="container py-5">
            @Body
        </div>
    </main>

    <footer class="public-footer border-top bg-white">
        <div class="container py-3 text-secondary small">
            &copy; @DateTime.Now.Year @L["AppName"]
        </div>
    </footer>
</div>
