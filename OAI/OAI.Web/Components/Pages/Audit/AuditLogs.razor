@page "/audit-logs"
@rendermode InteractiveServer

<PageTitle>@L["AuditLogsPageTitle"]</PageTitle>

<section class="mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <h1 class="fw-bold mb-1">@L["AuditLogsTitle"]</h1>
            <p class="text-secondary mb-0">
                @L["AuditLogsSubtitle"]
            </p>
        </div>

        <div class="d-flex align-items-start">
            <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@IsLoading">
                @L["Reload"]
            </button>
        </div>
    </div>
</section>

<section class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="row g-2 mb-4">
            <div class="col-12 col-lg">
                <input class="form-control"
                       placeholder="@L["AuditSearchPlaceholder"]"
                       @bind="Keyword"
                       @bind:event="oninput"
                       @onkeydown="HandleSearchKeyDown" />
            </div>

            <div class="col-12 col-md-3 col-lg-2">
                <select class="form-select" @bind="EntityName">
                    <option value="">@L["AllEntities"]</option>
                    <option value="Invoice">Invoice</option>
                    <option value="InvoiceLineItem">InvoiceLineItem</option>
                    <option value="ValidationIssue">ValidationIssue</option>
                    <option value="InvoiceExtractionResult">InvoiceExtractionResult</option>
                    <option value="Vendor">Vendor</option>
                </select>
            </div>

            <div class="col-12 col-md-3 col-lg-2">
                <select class="form-select" @bind="ActionType">
                    <option value="">@L["AllActions"]</option>
                    <option value="Created">Created</option>
                    <option value="Updated">Updated</option>
                    <option value="Deleted">Deleted</option>
                    <option value="Uploaded">Uploaded</option>
                    <option value="Processed">Processed</option>
                    <option value="Validated">Validated</option>
                    <option value="Exported">Exported</option>
                </select>
            </div>

            <div class="col-12 col-md-auto">
                <button class="btn btn-primary w-100" @onclick="SearchAsync" disabled="@IsLoading">
                    @L["Search"]
                </button>
            </div>

            <div class="col-12 col-md-auto">
                <button class="btn btn-outline-secondary w-100" @onclick="ClearSearchAsync" disabled="@IsLoading">
                    @L["ClearFilter"]
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="alert alert-danger">
                @ErrorMessage
            </div>
        }

        @if (IsLoading)
        {
            <div class="d-flex justify-content-center align-items-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <span class="ms-3 text-secondary">@L["LoadingAuditLogs"]</span>
            </div>
        }
        else if (Logs.Count == 0)
        {
            <div class="bg-light rounded-4 p-5 text-center">
                <div class="fs-1 mb-3">&#x1F558;</div>
                <h2 class="h5 fw-bold">@L["NoAuditLogs"]</h2>
                <p class="text-secondary mb-0">
                    @L["NoAuditLogsMatchFilter"]
                </p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                    <tr>
                        <th>@L["OccurredAt"]</th>
                        <th>@L["AuditEntity"]</th>
                        <th>@L["AuditAction"]</th>
                        <th>@L["AuditEntityId"]</th>
                        <th>@L["AuditUser"]</th>
                        <th>@L["AuditSource"]</th>
                        <th class="text-end">@L["Detail"]</th>
                    </tr>
                    </thead>

                    <tbody>
                    @foreach (var log in Logs)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">
                                    @FormatDateTime(log.OccurredAt)
                                </div>
                            </td>

                            <td>
                                <span class="badge text-bg-light border">
                                    @log.EntityName
                                </span>
                            </td>

                            <td>
                                <span class="badge @GetActionBadgeClass(log.ActionType)">
                                    @log.ActionType
                                </span>
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(log.EntityId))
                                {
                                    <code class="small">@log.EntityId</code>
                                }
                                else
                                {
                                    <span class="text-secondary">@L["NotAvailable"]</span>
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(log.UserName))
                                {
                                    <span>@log.UserName</span>
                                }
                                else if (!string.IsNullOrWhiteSpace(log.UserId))
                                {
                                    <span>@log.UserId</span>
                                }
                                else
                                {
                                    <span class="text-secondary">@L["System"]</span>
                                }
                            </td>

                            <td>
                                <span class="small text-secondary">
                                    @DisplayOrFallback(log.Source)
                                </span>
                            </td>

                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary"
                                        @onclick="() => SelectLog(log)">
                                    @L["View"]
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mt-4">
                <div class="text-secondary small">
                    @L["ShowingPage"] <strong>@PageNumber</strong>/<strong>@TotalPages</strong>,
                    @L["Total"] <strong>@TotalItems</strong> @L["AuditLogsLower"].
                </div>

                <div class="btn-group">
                    <button class="btn btn-outline-secondary"
                            disabled="@(!CanGoPrevious || IsLoading)"
                            @onclick="PreviousPageAsync">
                        @L["Previous"]
                    </button>

                    <button class="btn btn-outline-secondary"
                            disabled="@(!CanGoNext || IsLoading)"
                            @onclick="NextPageAsync">
                        @L["Next"]
                    </button>
                </div>
            </div>
        }
    </div>
</section>

@if (SelectedLog is not null)
{
    <section class="card border-0 shadow-sm rounded-4 mt-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <h2 class="h5 fw-bold mb-1">@L["AuditLogDetail"]</h2>
                    <p class="text-secondary mb-0">
                        @SelectedLog.EntityName - @SelectedLog.ActionType
                    </p>
                </div>

                <button class="btn btn-sm btn-outline-secondary" @onclick="CloseSelectedLog">
                    @L["Close"]
                </button>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <div class="border rounded-4 p-3 bg-light h-100">
                        <div class="text-secondary small">@L["AuditEntityId"]</div>
                        <div class="fw-semibold text-break">
                            @DisplayOrFallback(SelectedLog.EntityId)
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="border rounded-4 p-3 bg-light h-100">
                        <div class="text-secondary small">@L["AuditOccurredAt"]</div>
                        <div class="fw-semibold">
                            @FormatDateTime(SelectedLog.OccurredAt)
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="border rounded-4 p-3 bg-light h-100">
                        <div class="text-secondary small">@L["AuditCorrelationId"]</div>
                        <div class="fw-semibold text-break">
                            @DisplayOrFallback(SelectedLog.CorrelationId)
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-12 col-xl-6">
                    <h3 class="h6 fw-bold">@L["OldValues"]</h3>
                    <pre class="bg-light border rounded-4 p-3 small audit-json">@FormatJson(SelectedLog.OldValuesJson)</pre>
                </div>

                <div class="col-12 col-xl-6">
                    <h3 class="h6 fw-bold">@L["NewValues"]</h3>
                    <pre class="bg-light border rounded-4 p-3 small audit-json">@FormatJson(SelectedLog.NewValuesJson)</pre>
                </div>
            </div>
        </div>
    </section>
}
