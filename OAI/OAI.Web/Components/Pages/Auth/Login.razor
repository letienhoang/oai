@page "/login"
@rendermode InteractiveServer
@attribute [AllowAnonymous]

<PageTitle>@L["LoginPageTitle"]</PageTitle>

<section class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-lg-5">
                <h1 class="h3 fw-bold mb-2">@L["LoginTitle"]</h1>
                <p class="text-secondary mb-4">@L["LoginSubtitle"]</p>

                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <ErrorState Message="@ErrorMessage" InCard="false" CssClass="mb-4" />
                }

                <form method="post" action="@LoginActionUrl">
                    <AntiforgeryToken />
                    <div class="mb-3">
                        <label for="email" class="form-label">@L["Email"]</label>
                        <input id="email"
                               name="Email"
                               type="email"
                               class="form-control"
                               autocomplete="username"
                               required />
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">@L["Password"]</label>
                        <input id="password"
                               name="Password"
                               type="password"
                               class="form-control"
                               autocomplete="current-password"
                               required />
                    </div>

                    <div class="form-check mb-4">
                        <input id="rememberMe"
                               name="RememberMe"
                               type="checkbox"
                               value="true"
                               class="form-check-input" />
                        <label for="rememberMe" class="form-check-label">@L["RememberMe"]</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        @L["Login"]
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>
