@page "/"

<PageTitle>Dashboard - OAI</PageTitle>

<section class="mb-4">
    <h1 class="fw-bold mb-1">Dashboard</h1>
    <p class="text-secondary mb-0">
        Tổng quan hệ thống trích xuất thông tin hóa đơn.
    </p>
</section>

<section class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <div class="text-secondary fw-semibold small">Tổng hóa đơn</div>
                <div class="display-6 fw-bold mt-2">0</div>
                <div class="text-secondary small">Đã upload vào hệ thống</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <div class="text-secondary fw-semibold small">Đã xử lý</div>
                <div class="display-6 fw-bold mt-2">0</div>
                <div class="text-secondary small">OCR/extraction completed</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <div class="text-secondary fw-semibold small">Cần kiểm tra</div>
                <div class="display-6 fw-bold mt-2">0</div>
                <div class="text-secondary small">Có validation issues</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <div class="text-secondary fw-semibold small">Đã duyệt</div>
                <div class="display-6 fw-bold mt-2">0</div>
                <div class="text-secondary small">Approved invoices</div>
            </div>
        </div>
    </div>
</section>

<section class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
        <h2 class="h5 fw-bold mb-3">Luồng xử lý chính</h2>

        <ol class="mb-0 lh-lg">
            <li>Upload file hóa đơn PDF/ảnh.</li>
            <li>Lưu file gốc vào storage.</li>
            <li>Chạy OCR để lấy text thô.</li>
            <li>Trích xuất dữ liệu hóa đơn.</li>
            <li>Kiểm tra tính nhất quán dữ liệu.</li>
            <li>Người dùng xem, chỉnh sửa và xác nhận.</li>
        </ol>
    </div>
</section>