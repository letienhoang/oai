@page "/dev-tools/demo-data"
@rendermode InteractiveServer
@attribute [Authorize(Roles = ApplicationRoles.Administrator)]

<PageTitle>@L["DemoDataToolsPageTitle"]</PageTitle>

<section class="mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <h1 class="fw-bold mb-1">@L["DemoDataToolsTitle"]</h1>
            <p class="text-secondary mb-0">
                @L["DemoDataToolsSubtitle"]
            </p>
        </div>

        <div class="d-flex gap-2 align-items-start">
            <a class="btn btn-outline-secondary" href="/dev-tools/system-health">
                @L["SystemHealth"]
            </a>
        </div>
    </div>
</section>

@if (!IsDevelopment)
{
    <div class="alert alert-warning" role="alert">
        @L["DevelopmentOnlyWarning"]
    </div>
}
else
{
    <section class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h2 class="h5 fw-bold mb-1">@L["DemoDataToolsTitle"]</h2>
                    <p class="text-secondary mb-0">
                        @L["DevelopmentOnlyWarning"]
                    </p>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2">
                    <button class="btn btn-primary"
                            type="button"
                            @onclick="SeedDemoDataAsync"
                            disabled="@(IsSeeding || IsResetting)">
                        @if (IsSeeding)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>@L["SeedingDemoData"]</span>
                        }
                        else
                        {
                            <span>@L["SeedDemoData"]</span>
                        }
                    </button>

                    <button class="btn btn-outline-danger"
                            type="button"
                            @onclick="ConfirmResetDemoData"
                            disabled="@(IsSeeding || IsResetting)">
                        @if (IsResetting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>@L["ResettingDemoData"]</span>
                        }
                        else
                        {
                            <span>@L["ResetDemoData"]</span>
                        }
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="alert alert-danger mt-4 mb-0" role="alert">
                    @ErrorMessage
                </div>
            }
        </div>
    </section>

    <ConfirmDialog @ref="ConfirmDialog" />
}

@if (SeedResult is not null)
{
    <section class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">@L["DemoDataSeedResult"]</h2>

            <dl class="row mb-0">
                <dt class="col-12 col-md-4">@L["Skipped"]</dt>
                <dd class="col-12 col-md-8">@SeedResult.Skipped</dd>

                <dt class="col-12 col-md-4">@L["Message"]</dt>
                <dd class="col-12 col-md-8">@SeedResult.Message</dd>

                <dt class="col-12 col-md-4">@L["VendorsCreated"]</dt>
                <dd class="col-12 col-md-8">@SeedResult.VendorsCreated</dd>

                <dt class="col-12 col-md-4">@L["InvoicesCreated"]</dt>
                <dd class="col-12 col-md-8">@SeedResult.InvoicesCreated</dd>

                <dt class="col-12 col-md-4">@L["ValidationIssuesCreated"]</dt>
                <dd class="col-12 col-md-8">@SeedResult.ValidationIssuesCreated</dd>

                <dt class="col-12 col-md-4">@L["ExtractionResultsCreated"]</dt>
                <dd class="col-12 col-md-8">@SeedResult.ExtractionResultsCreated</dd>
            </dl>
        </div>
    </section>
}

@if (ResetResult is not null)
{
    <section class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">@L["DemoDataResetResult"]</h2>

            <dl class="row mb-0">
                <dt class="col-12 col-md-4">@L["Skipped"]</dt>
                <dd class="col-12 col-md-8">@ResetResult.Skipped</dd>

                <dt class="col-12 col-md-4">@L["Message"]</dt>
                <dd class="col-12 col-md-8">@ResetResult.Message</dd>

                <dt class="col-12 col-md-4">@L["VendorsDeleted"]</dt>
                <dd class="col-12 col-md-8">@ResetResult.VendorsDeleted</dd>

                <dt class="col-12 col-md-4">@L["InvoicesDeleted"]</dt>
                <dd class="col-12 col-md-8">@ResetResult.InvoicesDeleted</dd>

                <dt class="col-12 col-md-4">@L["LineItemsDeleted"]</dt>
                <dd class="col-12 col-md-8">@ResetResult.LineItemsDeleted</dd>

                <dt class="col-12 col-md-4">@L["ValidationIssuesDeleted"]</dt>
                <dd class="col-12 col-md-8">@ResetResult.ValidationIssuesDeleted</dd>

                <dt class="col-12 col-md-4">@L["ExtractionResultsDeleted"]</dt>
                <dd class="col-12 col-md-8">@ResetResult.ExtractionResultsDeleted</dd>
            </dl>
        </div>
    </section>
}
