@page "/Error"
@using System.Diagnostics
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["SystemErrorTitle"]</PageTitle>

<section class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-5">
        <h1 class="fw-bold text-danger mb-3">@L["SystemErrorHeading"]</h1>
        <p class="text-secondary">
            @L["SystemErrorDescription"]
        </p>

        @if (ShowRequestId)
        {
            <div class="alert alert-warning">
                <strong>@L["RequestId"]:</strong> <code>@RequestId</code>
            </div>
        }

        <h2 class="h5 fw-bold mt-4">@L["DevelopmentInformation"]</h2>
        <p class="text-secondary mb-0">
            @L["DevelopmentErrorDescription"]
        </p>
    </div>
</section>
