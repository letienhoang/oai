@page "/invoices/{InvoiceId:guid}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = ApplicationPolicies.ViewInvoices)]

<PageTitle>@L["InvoiceDetailPageTitle"]</PageTitle>

<section class="mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <h1 class="fw-bold mb-1">@L["InvoiceDetailTitle"]</h1>
            <p class="text-secondary mb-0">
                @L["InvoiceDetailSubtitle"]
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-start">
            <button class="btn btn-outline-secondary" @onclick="GoBack">
                @L["BackToList"]
            </button>

            @if (Invoice is not null)
            {
                <button class="btn btn-outline-primary" @onclick="GoToCompare">
                    @L["CompareOcrAi"]
                </button>

                <AuthorizeView Policy="@ApplicationPolicies.EditInvoices">
                    @if (CanShowEditButton)
                    {
                        <button class="btn btn-outline-secondary" @onclick="GoToEditAsync">
                            @L["Edit"]
                        </button>
                    }
                </AuthorizeView>

                <AuthorizeView Policy="@ApplicationPolicies.ApproveInvoices">
                    @if (CanShowApproveButton)
                    {
                        <button class="btn btn-success"
                                disabled="@IsApproving"
                                @onclick="ApproveAsync">
                            @if (IsApproving)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>@L["Approving"]</span>
                            }
                            else
                            {
                                <span>@L["ApproveInvoice"]</span>
                            }
                        </button>
                    }
                </AuthorizeView>

                <AuthorizeView Policy="@ApplicationPolicies.MoveInvoicesToPendingReview">
                    @if (CanShowMoveToPendingReviewButton)
                    {
                        <button class="btn btn-outline-warning"
                                disabled="@IsMovingToPendingReview"
                                @onclick="MoveToPendingReviewAsync">
                            @if (IsMovingToPendingReview)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>@L["Moving"]</span>
                            }
                            else
                            {
                                <span>@L["MoveToPendingReview"]</span>
                            }
                        </button>
                    }
                </AuthorizeView>

                <AuthorizeView Policy="@ApplicationPolicies.RejectInvoices">
                    @if (CanShowRejectButton)
                    {
                        <button class="btn btn-outline-danger"
                                disabled="@IsRejecting"
                                @onclick="RejectAsync">
                            @if (IsRejecting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>@L["Rejecting"]</span>
                            }
                            else
                            {
                                <span>@L["Reject"]</span>
                            }
                        </button>
                    }
                </AuthorizeView>
            }
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(SuccessMessage))
{
    <div class="alert alert-success">
        @SuccessMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(ActionErrorMessage))
{
    <div class="alert alert-danger">
        @ActionErrorMessage
    </div>
}

@if (Invoice is not null && string.Equals(Invoice.Status, "Rejected", StringComparison.OrdinalIgnoreCase))
{
    <div class="alert alert-warning">
        @L["InvoiceRejectedWarning"]
    </div>
}

@if (Invoice is not null && string.Equals(Invoice.Status, "Approved", StringComparison.OrdinalIgnoreCase))
{
    <div class="alert alert-success">
        @L["InvoiceApprovedMessage"]
    </div>
}

<PageState IsLoading="@IsLoading"
           LoadingMessage="@L["LoadingInvoiceDetail"]"
           ErrorTitle="@L["GenericErrorTitle"]"
           ErrorMessage="@ErrorMessage"
           IsEmpty="@(Invoice is null)"
           EmptyIcon="🧾"
           EmptyTitle="@L["InvoiceNotFound"]"
           EmptyMessage="@L["InvoiceNotFoundDescription"]"
           InCard="true">
    <ErrorActions>
        <button class="btn btn-outline-danger" @onclick="LoadInvoiceDetailAsync">
            @L["Retry"]
        </button>
    </ErrorActions>
    <EmptyActions>
        <button class="btn btn-primary" @onclick="GoBack">
            @L["BackToList"]
        </button>
    </EmptyActions>
    <ChildContent>
        @if (Invoice is not null)
        {
    <section class="row g-4">
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
                        <div>
                            <div class="text-secondary small fw-semibold">@L["InvoiceNumber"]</div>
                            <h2 class="h4 fw-bold mb-0">@Invoice.InvoiceNumber</h2>
                        </div>

                        <div class="text-md-end">
                            <div class="text-secondary small fw-semibold">@L["Status"]</div>
                            <span class="badge @GetStatusBadgeClass(Invoice.Status)">
                                @Invoice.Status
                            </span>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <div class="border rounded-4 p-3 bg-light h-100">
                                <div class="text-secondary small">@L["Vendor"]</div>
                                <div class="fw-semibold">@DisplayOrFallback(Invoice.VendorName)</div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="border rounded-4 p-3 bg-light h-100">
                                <div class="text-secondary small">@L["IssueDate"]</div>
                                <div class="fw-semibold">@Invoice.IssueDate.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="border rounded-4 p-3 bg-light h-100">
                                <div class="text-secondary small">@L["DueDate"]</div>
                                <div class="fw-semibold">
                                    @(Invoice.DueDate?.ToString("dd/MM/yyyy") ?? L["NotAvailable"].Value)
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="border rounded-4 p-3 bg-light h-100">
                                <div class="text-secondary small">@L["SourceFile"]</div>
                                <div class="fw-semibold text-break">
                                    @DisplayOrFallback(Invoice.SourceFileName)
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">@L["AmountSummary"]</h2>

                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <div class="border rounded-4 p-3">
                                <div class="text-secondary small">@L["Subtotal"]</div>
                                <div class="h5 fw-bold mb-0">
                                    @FormatMoney(Invoice.DeclaredSubtotal, Invoice.Currency)
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <div class="border rounded-4 p-3">
                                <div class="text-secondary small">@L["Tax"]</div>
                                <div class="h5 fw-bold mb-0">
                                    @FormatMoney(Invoice.DeclaredTaxAmount, Invoice.Currency)
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <div class="border rounded-4 p-3 bg-primary-subtle">
                                <div class="text-secondary small">@L["Total"]</div>
                                <div class="h5 fw-bold mb-0 text-primary">
                                    @FormatMoney(Invoice.DeclaredTotalAmount, Invoice.Currency)
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 fw-bold mb-0">@L["LineItems"]</h2>
                        <span class="badge text-bg-light border">
                            @Invoice.LineItems.Count @L["Rows"]
                        </span>
                    </div>

                    @if (Invoice.LineItems.Count == 0)
                    {
                        <div class="alert alert-warning mb-0">
                            @L["NoLineItemsExtracted"]
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead>
                                <tr>
                                    <th class="text-center">#</th>
                                    <th>@L["Description"]</th>
                                    <th class="text-end">@L["Quantity"]</th>
                                    <th class="text-end">@L["UnitPrice"]</th>
                                    <th class="text-end">@L["Net"]</th>
                                    <th class="text-end">@L["Tax"]</th>
                                    <th class="text-end">@L["TaxRate"]</th>
                                    <th class="text-end">@L["Gross"]</th>
                                </tr>
                                </thead>

                                <tbody>
                                @foreach (var item in Invoice.LineItems)
                                {
                                    <tr>
                                        <td class="text-center">@item.LineNo</td>
                                        <td>@item.Description</td>
                                        <td class="text-end">@item.Quantity:N2</td>
                                        <td class="text-end">@FormatMoney(item.UnitPrice, Invoice.Currency)</td>
                                        <td class="text-end">@FormatMoney(item.NetAmount, Invoice.Currency)</td>
                                        <td class="text-end">@FormatMoney(item.TaxAmount, Invoice.Currency)</td>
                                        <td class="text-end">@item.TaxRate:N2</td>
                                        <td class="text-end fw-semibold">
                                            @FormatMoney(item.GrossAmount, Invoice.Currency)
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (!CanApprove && string.Equals(Invoice.Status, "PendingReview", StringComparison.OrdinalIgnoreCase))
        {
            <div class="alert alert-warning">
                @L["CannotApproveDueToValidationErrors"]
            </div>
        }

        <div class="col-12 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">@L["ValidationIssues"]</h2>

                    @if (Invoice.ValidationIssues.Count == 0)
                    {
                        <div class="alert alert-success mb-0">
                            @L["NoConsistencyValidationIssues"]
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var issue in Invoice.ValidationIssues)
                            {
                                <div class="list-group-item px-0">
                                    <div class="d-flex justify-content-between gap-2 mb-1">
                                        <span class="badge @GetSeverityBadgeClass(issue.Severity)">
                                            @issue.Severity
                                        </span>

                                        @if (issue.IsResolved)
                                        {
                                            <span class="badge text-bg-success">@L["Resolved"]</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-warning">@L["Open"]</span>
                                        }
                                    </div>

                                    <div class="fw-semibold">@issue.RuleCode - @issue.FieldName</div>
                                    <div class="text-secondary small">@LocalizeMessage(issue.MessageCode, issue.MessageParameters, issue.Message)</div>
                                    <div class="text-secondary small mt-1">
                                        @FormatDateTime(issue.DetectedAt)
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">@L["ExtractionHistory"]</h2>

                    @if (Invoice.ExtractionResults.Count == 0)
                    {
                        <div class="alert alert-secondary mb-0">
                            @L["NoExtractionHistory"]
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var result in Invoice.ExtractionResults)
                            {
                                <div class="list-group-item px-0">
                                    <div class="d-flex justify-content-between gap-2 mb-1">
                                        <span class="fw-semibold">@result.EngineName</span>

                                        @if (result.IsSuccessful)
                                        {
                                            <span class="badge text-bg-success">@L["Success"]</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-danger">@L["Failed"]</span>
                                        }
                                    </div>

                                    <div class="text-secondary small">
                                        @L["Attempt"]: @result.AttemptNo
                                    </div>

                                    <div class="text-secondary small">
                                        @L["Confidence"]: @result.ConfidenceScore.ToString("P0")
                                    </div>

                                    <div class="text-secondary small">
                                        @FormatDateTime(result.ExtractedAt)
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
        }
    </ChildContent>
</PageState>
