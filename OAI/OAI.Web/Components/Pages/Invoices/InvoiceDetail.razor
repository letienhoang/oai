@page "/invoices/{InvoiceId:guid}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = ApplicationPolicies.ViewInvoices)]

<PageTitle>@L["InvoiceDetailPageTitle"]</PageTitle>

<ConfirmDialog @ref="ConfirmDialog" />
<ExtractionResultDetailDialog @ref="ExtractionResultDetailDialog" />

<section class="mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <h1 class="fw-bold mb-1">@L["InvoiceDetailTitle"]</h1>
            <p class="text-secondary mb-0">
                @L["InvoiceDetailSubtitle"]
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-start">
            <button class="btn btn-outline-secondary oai-icon-only-button"
                    title="@L["BackToList"]"
                    aria-label="@L["BackToList"]"
                    data-bs-toggle="tooltip"
                    data-bs-placement="top"
                    @onclick="GoBack">
                <Icon Name="mdi:arrow-left" Size="18" />
            </button>

            @if (Invoice is not null)
            {
                <button class="btn btn-outline-primary oai-icon-only-button"
                        title="@L["CompareOcrAi"]"
                        aria-label="@L["CompareOcrAi"]"
                        data-bs-toggle="tooltip"
                        data-bs-placement="top"
                        @onclick="GoToCompare">
                    <Icon Name="mdi:compare-horizontal" Size="18" />
                </button>

                <AuthorizeView Policy="@ApplicationPolicies.EditInvoices">
                    @if (CanShowEditButton)
                    {
                        <button class="btn btn-outline-secondary oai-icon-only-button"
                                title="@L["Edit"]"
                                aria-label="@L["Edit"]"
                                data-bs-toggle="tooltip"
                                data-bs-placement="top"
                                @onclick="GoToEditAsync">
                            <Icon Name="mdi:pencil-outline" Size="18" />
                        </button>
                    }
                </AuthorizeView>

                <AuthorizeView Policy="@ApplicationPolicies.ApproveInvoices">
                    @if (CanShowApproveButton)
                    {
                        <button class="btn btn-success oai-icon-only-button"
                                title="@L["ApproveInvoice"]"
                                aria-label="@L["ApproveInvoice"]"
                                data-bs-toggle="tooltip"
                                data-bs-placement="top"
                                disabled="@IsApproving"
                                @onclick="ConfirmApprove">
                            @if (IsApproving)
                            {
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                                <span class="visually-hidden">@L["Approving"]</span>
                            }
                            else
                            {
                                <Icon Name="mdi:check-circle-outline" Size="18" />
                            }
                        </button>
                    }
                </AuthorizeView>

                <AuthorizeView Policy="@ApplicationPolicies.MoveInvoicesToPendingReview">
                    @if (CanShowMoveToPendingReviewButton)
                    {
                        <button class="btn btn-outline-warning oai-icon-only-button"
                                title="@L["MoveToPendingReview"]"
                                aria-label="@L["MoveToPendingReview"]"
                                data-bs-toggle="tooltip"
                                data-bs-placement="top"
                                disabled="@IsMovingToPendingReview"
                                @onclick="ConfirmMoveToPendingReview">
                            @if (IsMovingToPendingReview)
                            {
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                                <span class="visually-hidden">@L["Moving"]</span>
                            }
                            else
                            {
                                <Icon Name="mdi:restore" Size="18" />
                            }
                        </button>
                    }
                </AuthorizeView>

                <AuthorizeView Policy="@ApplicationPolicies.RejectInvoices">
                    @if (CanShowRejectButton)
                    {
                        <button class="btn btn-outline-danger oai-icon-only-button"
                                title="@L["Reject"]"
                                aria-label="@L["Reject"]"
                                data-bs-toggle="tooltip"
                                data-bs-placement="top"
                                disabled="@IsRejecting"
                                @onclick="ConfirmReject">
                            @if (IsRejecting)
                            {
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                                <span class="visually-hidden">@L["Rejecting"]</span>
                            }
                            else
                            {
                                <Icon Name="mdi:close-circle-outline" Size="18" />
                            }
                        </button>
                    }
                </AuthorizeView>
            }
        </div>
    </div>
</section>

@if (Invoice is not null && string.Equals(Invoice.Status, "Rejected", StringComparison.OrdinalIgnoreCase))
{
    <div class="alert alert-warning">
        @L["InvoiceRejectedWarning"]
    </div>
}

@if (Invoice is not null && string.Equals(Invoice.Status, "Approved", StringComparison.OrdinalIgnoreCase))
{
    <div class="alert alert-success">
        @L["InvoiceApprovedMessage"]
    </div>
}

<PageState IsLoading="@IsLoading"
           LoadingMessage="@L["LoadingInvoiceDetail"]"
           ErrorTitle="@L["GenericErrorTitle"]"
           ErrorMessage="@ErrorMessage"
           IsEmpty="@(Invoice is null)"
           EmptyIcon="🧾"
           EmptyTitle="@L["InvoiceNotFound"]"
           EmptyMessage="@L["InvoiceNotFoundDescription"]"
           InCard="true">
    <ErrorActions>
        <button class="btn btn-outline-danger oai-icon-button" @onclick="LoadInvoiceDetailAsync">
            <Icon Name="mdi:refresh" Size="18" />
            <span>@L["Retry"]</span>
        </button>
    </ErrorActions>
    <EmptyActions>
        <button class="btn btn-primary oai-icon-button" @onclick="GoBack">
            <Icon Name="mdi:arrow-left" Size="18" />
            <span>@L["BackToList"]</span>
        </button>
    </EmptyActions>
    <ChildContent>
        @if (Invoice is not null)
        {
            <section class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="invoice-detail-header d-flex flex-column flex-xl-row justify-content-between gap-4 pb-4 mb-4 border-bottom">
                        <div class="invoice-detail-heading">
                            <div class="d-flex flex-column flex-sm-row align-items-sm-center gap-2 gap-sm-3 mb-3">
                                <h2 class="h3 fw-bold mb-0 text-break">@Invoice.InvoiceNumber</h2>
                                <span class="badge @GetStatusBadgeClass(Invoice.Status) align-self-start align-self-sm-center">
                                    @Invoice.Status
                                </span>
                            </div>

                            <div class="d-flex flex-column gap-1">
                                <span class="text-secondary small">@L["Vendor"]</span>
                                <span class="fw-semibold text-break">@DisplayOrFallback(Invoice.VendorName)</span>
                            </div>
                        </div>

                        <div class="invoice-detail-summary d-flex flex-column flex-sm-row flex-xl-nowrap gap-2 gap-sm-3 align-items-stretch">
                            <div class="invoice-detail-summary-item border rounded-3 bg-light">
                                <div class="text-secondary small">@L["LineItems"]</div>
                                <div class="fw-bold">@Invoice.LineItems.Count</div>
                            </div>

                            <div class="invoice-detail-summary-item border rounded-3 bg-light">
                                <div class="text-secondary small">@L["ValidationIssues"]</div>
                                <div class="fw-bold">@OpenValidationIssueCount</div>
                            </div>

                            @if (ErrorValidationIssueCount > 0)
                            {
                                <div class="invoice-detail-summary-item border border-danger-subtle rounded-3 bg-danger-subtle text-danger-emphasis">
                                    <div class="small">@L["Errors"]</div>
                                    <div class="fw-bold">@ErrorValidationIssueCount</div>
                                </div>
                            }
                        </div>
                    </div>

                    <ul class="nav nav-pills invoice-detail-tabs gap-2 mb-4">
                        <li class="nav-item">
                            <button type="button"
                                    class="@GetTabButtonClass(InvoiceDetailTab.Overview)"
                                    @onclick="() => SetActiveTab(InvoiceDetailTab.Overview)">
                                @L["Overview"]
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button"
                                    class="@GetTabButtonClass(InvoiceDetailTab.SourceFile)"
                                    @onclick="() => SetActiveTab(InvoiceDetailTab.SourceFile)">
                                @L["SourceFile"]
                                @if (Invoice.SourceFiles.Count > 0)
                                {
                                    <span class="badge text-bg-light ms-1">@Invoice.SourceFiles.Count</span>
                                }
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button"
                                    class="@GetTabButtonClass(InvoiceDetailTab.LineItems)"
                                    @onclick="() => SetActiveTab(InvoiceDetailTab.LineItems)">
                                @L["LineItems"]
                                <span class="badge text-bg-light ms-1">@Invoice.LineItems.Count</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button"
                                    class="@GetTabButtonClass(InvoiceDetailTab.Validation)"
                                    @onclick="() => SetActiveTab(InvoiceDetailTab.Validation)">
                                @L["ValidationIssues"]
                                <span class="badge text-bg-light ms-1">@OpenValidationIssueCount</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button"
                                    class="@GetTabButtonClass(InvoiceDetailTab.ExtractionHistory)"
                                    @onclick="() => SetActiveTab(InvoiceDetailTab.ExtractionHistory)">
                                @L["ExtractionHistory"]
                                <span class="badge text-bg-light ms-1">@Invoice.ExtractionResults.Count</span>
                            </button>
                        </li>
                    </ul>

                    @switch (ActiveTab)
                    {
                        case InvoiceDetailTab.Overview:
                            <div class="row g-4">
                                <div class="col-12 col-xl-5 order-xl-2">
                                    <div class="border rounded-4 p-4 h-100 bg-light">
                                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                            <h3 class="h6 fw-bold text-secondary text-uppercase mb-0">@L["AmountSummary"]</h3>
                                            <span class="badge bg-white text-secondary border">@Invoice.Currency</span>
                                        </div>

                                        <div class="border rounded-4 p-4 bg-white mb-3">
                                            <div class="text-secondary small mb-1">@L["Total"]</div>
                                            <div class="display-6 fw-bold text-primary lh-1 text-break">
                                                @FormatMoney(Invoice.DeclaredTotalAmount, Invoice.Currency)
                                            </div>
                                        </div>

                                        <div class="row g-3">
                                            <div class="col-12 col-sm-6">
                                                <div class="border rounded-3 p-3 bg-white h-100">
                                                    <div class="text-secondary small mb-1">@L["Subtotal"]</div>
                                                    <div class="fw-semibold text-break">
                                                        @FormatMoney(Invoice.DeclaredSubtotal, Invoice.Currency)
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-12 col-sm-6">
                                                <div class="border rounded-3 p-3 bg-white h-100">
                                                    <div class="text-secondary small mb-1">@L["Tax"]</div>
                                                    <div class="fw-semibold text-break">
                                                        @FormatMoney(Invoice.DeclaredTaxAmount, Invoice.Currency)
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-xl-7 order-xl-1">
                                    <div class="border rounded-4 p-4 h-100">
                                        <h3 class="h5 fw-bold mb-3">@L["GeneralInformation"]</h3>

                                        <div class="row g-3">
                                            <div class="col-12 col-md-6">
                                                <div class="border rounded-3 p-3 h-100">
                                                    <div class="text-secondary small mb-1">@L["Vendor"]</div>
                                                    <div class="fw-semibold text-break">@DisplayOrFallback(Invoice.VendorName)</div>
                                                </div>
                                            </div>

                                            <div class="col-12 col-md-6">
                                                <div class="border rounded-3 p-3 h-100">
                                                    <div class="text-secondary small mb-1">@L["IssueDate"]</div>
                                                    <div class="fw-semibold">@Invoice.IssueDate.ToString("dd/MM/yyyy")</div>
                                                </div>
                                            </div>

                                            <div class="col-12 col-md-6">
                                                <div class="border rounded-3 p-3 h-100">
                                                    <div class="text-secondary small mb-1">@L["DueDate"]</div>
                                                    <div class="fw-semibold">
                                                        @(Invoice.DueDate?.ToString("dd/MM/yyyy") ?? L["NotAvailable"].Value)
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-12 col-md-6">
                                                <div class="border rounded-3 p-3 h-100">
                                                    <div class="text-secondary small mb-1">@L["SourceFile"]</div>
                                                    <div class="fw-semibold text-break">
                                                        @DisplayOrFallback(Invoice.SourceFileName)
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @if (!CanApprove && string.Equals(Invoice.Status, "PendingReview", StringComparison.OrdinalIgnoreCase))
                                {
                                    <div class="col-12">
                                        <div class="alert alert-warning mb-0">
                                            @L["CannotApproveDueToValidationErrors"]
                                        </div>
                                    </div>
                                }
                            </div>
                            break;

                        case InvoiceDetailTab.SourceFile:
                            <div class="source-file-viewer">
                                <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-3">
                                    <div>
                                        <h3 class="h5 fw-bold mb-1">@L["SourceFileViewer"]</h3>
                                        <p class="text-secondary mb-0">
                                            @L["SourceFileViewerDescription"]
                                        </p>
                                    </div>

                                    @if (SelectedSourceFile is not null)
                                    {
                                        <a class="btn btn-outline-primary oai-icon-button align-self-start"
                                           href="@GetDownloadUrl(SelectedSourceFile.Id)"
                                           target="_blank"
                                           rel="noopener">
                                            <Icon Name="mdi:download-outline" Size="18" />
                                            <span>@L["DownloadSourceFile"]</span>
                                        </a>
                                    }
                                </div>

                                @if (OrderedSourceFiles.Count == 0)
                                {
                                    <div class="border rounded-4 bg-light p-4 text-center text-secondary">
                                        @L["NoSourceFileAvailable"]
                                    </div>
                                }
                                else if (SelectedSourceFile is not null)
                                {
                                    @if (OrderedSourceFiles.Count > 1)
                                    {
                                        <div class="row g-3 align-items-end mb-3">
                                            <div class="col-12 col-md-5 col-xl-4">
                                                <label class="form-label fw-semibold" for="sourceFileSelector">
                                                    @L["SelectSourcePage"]
                                                </label>
                                                <select id="sourceFileSelector"
                                                        class="form-select"
                                                        value="@SelectedSourceFile.Id"
                                                        @onchange="OnSelectedSourceFileChanged">
                                                    @foreach (var sourceFile in OrderedSourceFiles)
                                                    {
                                                        <option value="@sourceFile.Id">@GetSourceFileLabel(sourceFile)</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    }

                                    <div class="row g-3 mb-3">
                                        <div class="col-12 col-md-4">
                                            <div class="border rounded-3 p-3 h-100">
                                                <div class="text-secondary small mb-1">@L["OriginalFile"]</div>
                                                <div class="fw-semibold text-break">@DisplayOrFallback(SelectedSourceFile.OriginalFileName)</div>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <div class="border rounded-3 p-3 h-100">
                                                <div class="text-secondary small mb-1">@L["ContentType"]</div>
                                                <div class="fw-semibold text-break">@DisplayOrFallback(SelectedSourceFile.ContentType)</div>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <div class="border rounded-3 p-3 h-100">
                                                <div class="text-secondary small mb-1">@L["FileSize"]</div>
                                                <div class="fw-semibold">@FormatFileSize(SelectedSourceFile.FileSizeBytes)</div>
                                            </div>
                                        </div>
                                    </div>

                                    @if (IsPdfContentType(SelectedSourceFile.ContentType))
                                    {
                                        <iframe src="@GetPreviewUrl(SelectedSourceFile.Id)"
                                                class="source-file-frame"
                                                title="@L["SourceFileViewer"]"></iframe>
                                    }
                                    else if (IsImageContentType(SelectedSourceFile.ContentType))
                                    {
                                        <div class="source-file-image-wrapper">
                                            <img src="@GetPreviewUrl(SelectedSourceFile.Id)"
                                                 class="source-file-image"
                                                 alt="@L["InvoiceSourceFilePreviewAlt"]" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="border rounded-4 bg-light p-4 text-center">
                                            <p class="text-secondary mb-3">@L["PreviewNotAvailable"]</p>
                                            <a class="btn btn-outline-primary oai-icon-button"
                                               href="@GetDownloadUrl(SelectedSourceFile.Id)"
                                               target="_blank"
                                               rel="noopener">
                                                <Icon Name="mdi:download-outline" Size="18" />
                                                <span>@L["DownloadSourceFile"]</span>
                                            </a>
                                        </div>
                                    }
                                }
                            </div>
                            break;

                        case InvoiceDetailTab.LineItems:
                            <div>
                                <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
                                    <h3 class="h5 fw-bold mb-0">@L["LineItems"]</h3>
                                    <span class="badge text-bg-light border">
                                        @Invoice.LineItems.Count @L["Rows"]
                                    </span>
                                </div>

                                @if (Invoice.LineItems.Count == 0)
                                {
                                    <EmptyState Icon=""
                                                Title="@L["NoLineItemsExtracted"]"
                                                InCard="false" />
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle mb-0">
                                            <thead>
                                            <tr>
                                                <th class="text-center">#</th>
                                                <th>@L["Description"]</th>
                                                <th class="text-end">@L["Quantity"]</th>
                                                <th class="text-end">@L["UnitPrice"]</th>
                                                <th class="text-end">@L["Net"]</th>
                                                <th class="text-end">@L["Tax"]</th>
                                                <th class="text-end">@L["TaxRate"]</th>
                                                <th class="text-end">@L["Gross"]</th>
                                            </tr>
                                            </thead>

                                            <tbody>
                                            @foreach (var item in Invoice.LineItems)
                                            {
                                                <tr>
                                                    <td class="text-center">@item.LineNo</td>
                                                    <td>@item.Description</td>
                                                    <td class="text-end">@item.Quantity.ToString("N2")</td>
                                                    <td class="text-end">@FormatMoney(item.UnitPrice, Invoice.Currency)</td>
                                                    <td class="text-end">@FormatMoney(item.NetAmount, Invoice.Currency)</td>
                                                    <td class="text-end">@FormatMoney(item.TaxAmount, Invoice.Currency)</td>
                                                    <td class="text-end">@item.TaxRate.ToString("N2")</td>
                                                    <td class="text-end fw-semibold">
                                                        @FormatMoney(item.GrossAmount, Invoice.Currency)
                                                    </td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                            break;

                        case InvoiceDetailTab.Validation:
                            <div>
                                <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-3">
                                    <div>
                                        <h3 class="h5 fw-bold mb-1">@L["ValidationIssues"]</h3>
                                        <p class="text-secondary mb-0">
                                            @L["ValidationIssuesTabDescription"]
                                        </p>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2 align-items-start">
                                        <span class="badge text-bg-light border">
                                            @Invoice.ValidationIssues.Count @L["Total"]
                                        </span>
                                        <span class="badge text-bg-warning">
                                            @OpenValidationIssueCount @L["Open"]
                                        </span>
                                    </div>
                                </div>

                                @if (Invoice.ValidationIssues.Count == 0)
                                {
                                    <EmptyState Icon=""
                                                Title="@L["NoConsistencyValidationIssues"]"
                                                InCard="false" />
                                }
                                else
                                {
                                    <div class="list-group list-group-flush">
                                        @foreach (var issue in Invoice.ValidationIssues)
                                        {
                                            <div class="list-group-item px-0">
                                                <div class="d-flex justify-content-between gap-2 mb-1">
                                                    <span class="badge @GetSeverityBadgeClass(issue.Severity)">
                                                        @issue.Severity
                                                    </span>

                                                    @if (issue.IsResolved)
                                                    {
                                                        <span class="badge text-bg-success">@L["Resolved"]</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge text-bg-warning">@L["Open"]</span>
                                                    }
                                                </div>

                                                <div class="fw-semibold">@issue.RuleCode - @issue.FieldName</div>
                                                <div class="text-secondary small">@LocalizeMessage(issue.MessageCode, issue.MessageParameters, issue.Message)</div>
                                                <div class="text-secondary small mt-1">
                                                    @FormatDateTime(issue.DetectedAt)
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                            break;

                        case InvoiceDetailTab.ExtractionHistory:
                            <div>
                                <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-3">
                                    <div>
                                        <h3 class="h5 fw-bold mb-1">@L["ExtractionHistory"]</h3>
                                        <p class="text-secondary mb-0">
                                            @L["ExtractionHistoryDescription"]
                                        </p>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2 align-items-start">
                                        <span class="badge text-bg-light border">
                                            @Invoice.ExtractionResults.Count @L["Attempts"]
                                        </span>
                                    </div>
                                </div>

                                @if (Invoice.ExtractionResults.Count == 0)
                                {
                                    <EmptyState Icon=""
                                                Title="@L["NoExtractionHistory"]"
                                                InCard="false" />
                                }
                                else
                                {
                                    <div class="row g-3 mb-4">
                                        <div class="col-12 col-md-4">
                                            <div class="border rounded-4 p-3 bg-light h-100">
                                                <div class="text-secondary small">@L["TotalAttempts"]</div>
                                                <div class="h4 fw-bold mb-0">@Invoice.ExtractionResults.Count</div>
                                            </div>
                                        </div>

                                        <div class="col-12 col-md-4">
                                            <div class="border rounded-4 p-3 bg-light h-100">
                                                <div class="text-secondary small">@L["SuccessfulAttempts"]</div>
                                                <div class="h4 fw-bold mb-0">@SuccessfulExtractionCount</div>
                                            </div>
                                        </div>

                                        <div class="col-12 col-md-4">
                                            <div class="border rounded-4 p-3 bg-light h-100">
                                                <div class="text-secondary small">@L["LatestConfidence"]</div>
                                                <div class="h4 fw-bold mb-0">
                                                    @(LatestExtractionResult?.ConfidenceScore.ToString("P0") ?? L["NoData"].Value)
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle mb-0">
                                            <thead>
                                            <tr>
                                                <th>@L["Attempt"]</th>
                                                <th>@L["Engine"]</th>
                                                <th>@L["Status"]</th>
                                                <th class="text-end">@L["Confidence"]</th>
                                                <th>@L["ExtractedAt"]</th>
                                                <th class="text-end">@L["Actions"]</th>
                                            </tr>
                                            </thead>

                                            <tbody>
                                            @foreach (var result in Invoice.ExtractionResults.OrderByDescending(x => x.ExtractedAt))
                                            {
                                                <tr>
                                                    <td class="fw-semibold">@result.AttemptNo</td>
                                                    <td class="text-break">@result.EngineName</td>
                                                    <td>
                                                        @if (result.IsSuccessful)
                                                        {
                                                            <span class="badge text-bg-success">@L["Success"]</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge text-bg-danger">@L["Failed"]</span>
                                                        }
                                                    </td>
                                                    <td class="text-end">@result.ConfidenceScore.ToString("P0")</td>
                                                    <td>@FormatDateTime(result.ExtractedAt)</td>
                                                    <td class="text-end">
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-primary oai-icon-only-button"
                                                                title="@L["Detail"]"
                                                                aria-label="@L["Detail"]"
                                                                data-bs-toggle="tooltip"
                                                                data-bs-placement="top"
                                                                @onclick="() => OpenExtractionResultDetailAsync(result)">
                                                            <Icon Name="mdi:eye-outline" Size="16" />
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                            break;
                    }
                </div>
            </section>
        }
    </ChildContent>
</PageState>
