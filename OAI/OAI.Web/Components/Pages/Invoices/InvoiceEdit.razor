@page "/invoices/{InvoiceId:guid}/edit"
@rendermode InteractiveServer
@attribute [Authorize(Policy = ApplicationPolicies.EditInvoices)]

<PageTitle>@L["EditInvoicePageTitle"]</PageTitle>

<section class="mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <h1 class="fw-bold mb-1">@L["EditInvoiceTitle"]</h1>
            <p class="text-secondary mb-0">
                @L["EditInvoiceSubtitle"]
            </p>
        </div>

        <div class="d-flex gap-2 align-items-start">
            <button class="btn btn-outline-secondary" @onclick="GoBack" disabled="@IsSaving">
                @L["Back"]
            </button>
        </div>
    </div>
</section>

<PageState IsLoading="@IsLoading"
           LoadingMessage="@L["LoadingInvoiceData"]"
           ErrorTitle="@L["GenericErrorTitle"]"
           ErrorMessage="@ErrorMessage"
           IsEmpty="false"
           InCard="true">
    <ChildContent>
    <EditForm EditContext="EditContext" OnValidSubmit="SaveAsync">
        <div class="row g-4">
            <div class="col-12 col-xl-8">
                <section class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-3">@L["GeneralInformation"]</h2>

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label">@L["InvoiceNumber"]</label>
                                <InputText class="form-control" @bind-Value="EditModel.InvoiceNumber" />
                                <ValidationMessage For="@(() => EditModel.InvoiceNumber)" />
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label">@L["Vendor"]</label>
                                <InputSelect class="form-select"
                                             @bind-Value="EditModel.VendorIdText"
                                             disabled="@IsSaving">
                                    <option value="">@L["SelectVendor"]</option>
                                    @foreach (var vendor in VendorOptions)
                                    {
                                        <option value="@vendor.VendorId.ToString()">
                                            @vendor.Name
                                        </option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => EditModel.VendorIdText)" />
                                @if (VendorOptions.Count == 0)
                                {
                                    <div class="form-text text-warning">
                                        @L["NoVendorsAvailable"]
                                    </div>
                                }
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label">@L["IssueDate"]</label>
                                <InputDate class="form-control" @bind-Value="EditModel.IssueDate" />
                                <ValidationMessage For="@(() => EditModel.IssueDate)" />
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label">@L["DueDate"]</label>
                                <InputDate class="form-control" @bind-Value="EditModel.DueDate" />
                            </div>

                            <div class="col-12 col-md-4">
                                <label class="form-label">@L["Currency"]</label>
                                <InputSelect class="form-select" @bind-Value="EditModel.Currency">
                                    <option value="VND">VND</option>
                                    <option value="USD">USD</option>
                                    <option value="EUR">EUR</option>
                                </InputSelect>
                            </div>

                            <div class="col-12 col-md-4">
                                <label class="form-label">@L["Subtotal"]</label>
                                <InputNumber class="form-control" @bind-Value="EditModel.DeclaredSubtotal" />
                            </div>

                            <div class="col-12 col-md-4">
                                <label class="form-label">@L["Tax"]</label>
                                <InputNumber class="form-control" @bind-Value="EditModel.DeclaredTaxAmount" />
                            </div>

                            <div class="col-12 col-md-4">
                                <label class="form-label">@L["Total"]</label>
                                <InputNumber class="form-control" @bind-Value="EditModel.DeclaredTotalAmount" />
                            </div>
                        </div>
                    </div>
                </section>

                <section class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h2 class="h5 fw-bold mb-0">@L["LineItems"]</h2>

                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddLineItem">
                                @L["AddLineItem"]
                            </button>
                        </div>

                        @if (EditModel.LineItems.Count == 0)
                        {
                            <div class="alert alert-warning mb-0">
                                @L["AtLeastOneLineItemRequired"]
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead>
                                    <tr>
                                        <th style="width: 80px;">#</th>
                                        <th>@L["Description"]</th>
                                        <th style="width: 130px;" class="text-end">@L["Quantity"]</th>
                                        <th style="width: 150px;" class="text-end">@L["UnitPrice"]</th>
                                        <th style="width: 120px;" class="text-end">@L["TaxRate"]</th>
                                        <th style="width: 90px;" class="text-end"></th>
                                    </tr>
                                    </thead>

                                    <tbody>
                                    @for (var i = 0; i < EditModel.LineItems.Count; i++)
                                    {
                                        var index = i;
                                        var item = EditModel.LineItems[index];

                                        <tr>
                                            <td>
                                                <InputNumber class="form-control" @bind-Value="item.LineNo" />
                                            </td>

                                            <td>
                                                <InputText class="form-control" @bind-Value="item.Description" />
                                            </td>

                                            <td>
                                                <InputNumber class="form-control text-end" @bind-Value="item.Quantity" />
                                            </td>

                                            <td>
                                                <InputNumber class="form-control text-end" @bind-Value="item.UnitPrice" />
                                            </td>

                                            <td>
                                                <InputNumber class="form-control text-end" @bind-Value="item.TaxRate" />
                                            </td>

                                            <td class="text-end">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => RemoveLineItem(index)"
                                                        disabled="@(EditModel.LineItems.Count <= 1)">
                                                    @L["Delete"]
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </section>
            </div>

            <div class="col-12 col-xl-4">
                <section class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-3">@L["Tasks"]</h2>

                        @if (!string.IsNullOrWhiteSpace(SuccessMessage))
                        {
                            <div class="alert alert-success">
                                @SuccessMessage
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(FormErrorMessage))
                        {
                            <div class="alert alert-danger">
                                @FormErrorMessage
                            </div>
                        }

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary" disabled="@IsSaving">
                                @if (IsSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    <span>@L["Saving"]</span>
                                }
                                else
                                {
                                    <span>@L["SaveAndRevalidate"]</span>
                                }
                            </button>

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    @onclick="GoBack"
                                    disabled="@IsSaving">
                                @L["Cancel"]
                            </button>
                        </div>
                    </div>
                </section>

                <section class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-3">@L["Notes"]</h2>

                        <ul class="small text-secondary mb-0 lh-lg">
                            <li>@L["EditNoteRunValidation"]</li>
                            <li>@L["EditNoteReplaceOldValidationIssues"]</li>
                            <li>@L["EditNoteOriginalOcrNotModified"]</li>
                        </ul>
                    </div>
                </section>
            </div>
        </div>
    </EditForm>
    </ChildContent>
</PageState>
