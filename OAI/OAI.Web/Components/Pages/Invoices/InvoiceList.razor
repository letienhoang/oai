@page "/invoices"
@rendermode InteractiveServer

<PageTitle>@L["InvoiceListPageTitle"]</PageTitle>

<section class="mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <h1 class="fw-bold mb-1">@L["InvoiceListTitle"]</h1>
            <p class="text-secondary mb-0">
                @L["InvoiceListSubtitle"]
            </p>
        </div>

        <div class="d-flex align-items-start">
            <button class="btn btn-primary" @onclick="GoToUpload">
                @L["UploadInvoice"]
            </button>
        </div>
    </div>
</section>

<section class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="row g-2 mb-4">
            <div class="col-12 col-md">
                <input class="form-control"
                       placeholder="@L["InvoiceSearchPlaceholder"]"
                       @bind="Keyword"
                       @bind:event="oninput"
                       @onkeydown="HandleSearchKeyDown" />
            </div>

            <div class="col-12 col-md-auto">
                <button class="btn btn-primary w-100"
                        disabled="@IsLoading"
                        @onclick="SearchAsync">
                    @L["Search"]
                </button>
            </div>

            <div class="col-12 col-md-auto">
                <button class="btn btn-outline-secondary w-100"
                        disabled="@IsLoading"
                        @onclick="ClearSearchAsync">
                    @L["ClearFilter"]
                </button>
            </div>
        </div>

        <PageState IsLoading="@IsLoading"
                   LoadingMessage="@L["LoadingInvoiceList"]"
                   ErrorTitle="@L["GenericErrorTitle"]"
                   ErrorMessage="@ErrorMessage"
                   IsEmpty="@(Invoices.Count == 0)"
                   EmptyIcon="🧾"
                   EmptyTitle="@L["NoData"]"
                   EmptyMessage="@L["NoInvoicesMatchSearch"]"
                   InCard="false">
            <EmptyActions>
                <button class="btn btn-primary" @onclick="GoToUpload">
                    @L["UploadFirstInvoice"]
                </button>
            </EmptyActions>
            <ChildContent>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                    <tr>
                        <th>@L["InvoiceNumber"]</th>
                        <th>@L["Vendor"]</th>
                        <th>@L["IssueDate"]</th>
                        <th class="text-end">@L["TotalAmount"]</th>
                        <th>@L["Status"]</th>
                        <th class="text-center">@L["LineItems"]</th>
                        <th class="text-end">@L["Actions"]</th>
                    </tr>
                    </thead>

                    <tbody>
                    @foreach (var invoice in Invoices)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@invoice.InvoiceNumber</div>
                                <div class="small text-secondary">
                                    <code>@invoice.InvoiceId</code>
                                </div>
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(invoice.VendorName))
                                {
                                    <span>@invoice.VendorName</span>
                                }
                                else
                                {
                                    <span class="text-secondary">@L["UnknownVendor"]</span>
                                }
                            </td>

                            <td>@invoice.IssueDate.ToString("dd/MM/yyyy")</td>

                            <td class="text-end">
                                <span class="fw-semibold">
                                    @FormatMoney(invoice.TotalAmount, invoice.Currency)
                                </span>
                            </td>

                            <td>
                                <span class="badge @GetStatusBadgeClass(invoice.Status)">
                                    @invoice.Status
                                </span>
                            </td>

                            <td class="text-center">
                                <span class="badge text-bg-light border">
                                    @invoice.LineItemCount
                                </span>
                            </td>

                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary"
                                        @onclick="() => GoToDetail(invoice.InvoiceId)">
                                    @L["Detail"]
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mt-4">
                <div class="text-secondary small">
                    @L["ShowingPage"] <strong>@PageNumber</strong>@L["Of"]<strong>@TotalPages</strong>,
                    @L["Total"] <strong>@TotalItems</strong> @L["InvoicesLower"].
                </div>

                <div class="btn-group">
                    <button class="btn btn-outline-secondary"
                            disabled="@(!CanGoPrevious || IsLoading)"
                            @onclick="PreviousPageAsync">
                        @L["Previous"]
                    </button>

                    <button class="btn btn-outline-secondary"
                            disabled="@(!CanGoNext || IsLoading)"
                            @onclick="NextPageAsync">
                        @L["Next"]
                    </button>
                </div>
            </div>
            </ChildContent>
        </PageState>
    </div>
</section>
