@page "/invoices/upload"
@rendermode InteractiveServer

<PageTitle>Upload hóa đơn - OAI</PageTitle>

<section class="mb-4">
    <h1 class="fw-bold mb-1">Upload hóa đơn</h1>
    <p class="text-secondary mb-0">
        Tải lên ảnh hóa đơn để hệ thống lưu trữ, OCR, trích xuất dữ liệu và tạo bản ghi hóa đơn.
    </p>
</section>

<section class="row g-4">
    <div class="col-12 col-xl-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Chọn file hóa đơn</h2>

                <div class="border border-2 border-dashed rounded-4 p-5 text-center bg-light">
                    <div class="fs-1 mb-3">⬆️</div>

                    <h3 class="h6 fw-bold">Upload ảnh hóa đơn</h3>

                    <p class="text-secondary small mb-4">
                        Hỗ trợ hiện tại: JPG, JPEG, PNG, TIF, TIFF. PDF sẽ được hỗ trợ ở giai đoạn sau.
                    </p>

                    <InputFile OnChange="HandleFileSelectedAsync"
                               accept=".jpg,.jpeg,.png,.tif,.tiff"
                               class="form-control" />
                </div>

                @if (SelectedFileName is not null)
                {
                    <div class="alert alert-info mt-4 mb-0">
                        <div><strong>File đã chọn:</strong> @SelectedFileName</div>
                        <div><strong>Dung lượng:</strong> @SelectedFileSizeText</div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <div class="alert alert-danger mt-4 mb-0">
                        @ErrorMessage
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(SuccessMessage))
                {
                    <div class="alert alert-success mt-4 mb-0">
                        @SuccessMessage
                    </div>
                }

                <div class="d-flex gap-2 mt-4">
                    <button class="btn btn-primary"
                            disabled="@(!CanUpload || IsUploading)"
                            @onclick="UploadAsync">
                        @if (IsUploading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Đang xử lý...</span>
                        }
                        else
                        {
                            <span>Upload và xử lý</span>
                        }
                    </button>

                    <button class="btn btn-outline-secondary"
                            disabled="@IsUploading"
                            @onclick="ResetForm">
                        Làm mới
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-4">
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Luồng xử lý</h2>

                <ol class="small text-secondary mb-0 lh-lg">
                    <li>Lưu file hóa đơn vào storage.</li>
                    <li>Chạy OCR bằng Tesseract.</li>
                    <li>Parse text OCR thành dữ liệu hóa đơn.</li>
                    <li>Tạo invoice trong database.</li>
                    <li>Kiểm tra tính nhất quán dữ liệu.</li>
                </ol>
            </div>
        </div>

        @if (UploadResult is not null)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">Kết quả xử lý</h2>

                    <dl class="row small mb-0">
                        <dt class="col-5">Trạng thái</dt>
                        <dd class="col-7">
                            <span class="badge @GetStatusBadgeClass(UploadResult.Status)">
                                @UploadResult.Status
                            </span>
                        </dd>

                        <dt class="col-5">File</dt>
                        <dd class="col-7 text-break">@UploadResult.FileName</dd>

                        <dt class="col-5">InvoiceId</dt>
                        <dd class="col-7 text-break">
                            @if (UploadResult.InvoiceId != Guid.Empty)
                            {
                                <code>@UploadResult.InvoiceId</code>
                            }
                            else
                            {
                                <span class="text-secondary">N/A</span>
                            }
                        </dd>

                        <dt class="col-5">Thông báo</dt>
                        <dd class="col-7">@UploadResult.Message</dd>
                    </dl>

                    @if (UploadResult.InvoiceId != Guid.Empty)
                    {
                        <button class="btn btn-sm btn-outline-primary mt-3"
                                @onclick="GoToInvoiceDetail">
                            Xem chi tiết hóa đơn
                        </button>
                    }
                </div>
            </div>
        }
    </div>
</section>