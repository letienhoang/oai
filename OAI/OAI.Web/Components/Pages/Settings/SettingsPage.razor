@page "/settings"
@rendermode InteractiveServer
@attribute [Authorize(Policy = ApplicationPolicies.ViewSettings)]

<PageTitle>@L["SettingsPageTitle"]</PageTitle>

<section class="mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <h1 class="fw-bold mb-1">@L["SettingsTitle"]</h1>
            <p class="text-secondary mb-0">
                @L["SettingsSubtitle"]
            </p>
        </div>

        <div class="d-flex align-items-start">
            <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@IsLoading">
                @L["Reload"]
            </button>
        </div>
    </div>
</section>

@if (IsLoading)
{
    <section class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-5 text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <div class="text-secondary mt-3">@L["LoadingSystemSettings"]</div>
        </div>
    </section>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <section class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-5">
            <div class="alert alert-danger mb-0">
                @ErrorMessage
            </div>
        </div>
    </section>
}
else if (Settings is not null)
{
    <section class="row g-4">
        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h2 class="h5 fw-bold mb-1">File Storage</h2>
                            <p class="text-secondary small mb-0">
                                @L["FileStorageDescription"]
                            </p>
                        </div>

                        <span class="badge text-bg-primary">Storage</span>
                    </div>

                    <dl class="row small mb-0">
                        <dt class="col-5">BasePath</dt>
                        <dd class="col-7 text-break">@Settings.FileStorage.BasePath</dd>

                        <dt class="col-5">RootPath</dt>
                        <dd class="col-7 text-break">@Settings.FileStorage.RootPath</dd>

                        <dt class="col-5">InvoiceFolder</dt>
                        <dd class="col-7 text-break">@Settings.FileStorage.InvoiceFolder</dd>

                        <dt class="col-5">MaxFileSize</dt>
                        <dd class="col-7">
                            @Settings.FileStorage.MaxFileSizeDisplay
                            <span class="text-secondary">
                                (@Settings.FileStorage.MaxFileSizeBytes bytes)
                            </span>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h2 class="h5 fw-bold mb-1">OCR</h2>
                            <p class="text-secondary small mb-0">
                                @L["OcrSettingsDescription"]
                            </p>
                        </div>

                        <span class="badge text-bg-info">Tesseract</span>
                    </div>

                    <dl class="row small mb-0">
                        <dt class="col-5">BasePath</dt>
                        <dd class="col-7 text-break">@Settings.Ocr.BasePath</dd>

                        <dt class="col-5">TessDataPath</dt>
                        <dd class="col-7 text-break">@Settings.Ocr.TessDataPath</dd>

                        <dt class="col-5">Languages</dt>
                        <dd class="col-7">
                            <span class="badge text-bg-light border">
                                @Settings.Ocr.Languages
                            </span>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h2 class="h5 fw-bold mb-1">AI / LLM</h2>
                            <p class="text-secondary small mb-0">
                                @L["AiSettingsDescription"]
                            </p>
                        </div>

                        @if (Settings.Llm.Enabled)
                        {
                            <span class="badge text-bg-success">@L["Enabled"]</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@L["Disabled"]</span>
                        }
                    </div>

                    <dl class="row small mb-0">
                        <dt class="col-5">Provider</dt>
                        <dd class="col-7">@Settings.Llm.Provider</dd>

                        <dt class="col-5">Model</dt>
                        <dd class="col-7">
                            <code>@Settings.Llm.Model</code>
                        </dd>

                        <dt class="col-5">MaxInputCharacters</dt>
                        <dd class="col-7">@Settings.Llm.MaxInputCharacters</dd>

                        <dt class="col-5">API Key</dt>
                        <dd class="col-7">
                            @if (Settings.Llm.HasApiKey)
                            {
                                <span class="badge text-bg-success">@Settings.Llm.ApiKeyStatus</span>
                            }
                            else
                            {
                                <span class="badge text-bg-warning">@Settings.Llm.ApiKeyStatus</span>
                            }
                        </dd>
                    </dl>

                    <div class="alert alert-warning mt-3 mb-0 small">
                        @L["ApiKeyHiddenWarning"]
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h2 class="h5 fw-bold mb-1">Runtime</h2>
                            <p class="text-secondary small mb-0">
                                @L["RuntimeSettingsDescription"]
                            </p>
                        </div>

                        <span class="badge text-bg-dark">Runtime</span>
                    </div>

                    <dl class="row small mb-0">
                        <dt class="col-5">Environment</dt>
                        <dd class="col-7">
                            <span class="badge @GetEnvironmentBadgeClass(Settings.Runtime.EnvironmentName)">
                                @Settings.Runtime.EnvironmentName
                            </span>
                        </dd>

                        <dt class="col-5">Application</dt>
                        <dd class="col-7">@Settings.Runtime.ApplicationName</dd>

                        <dt class="col-5">ContentRoot</dt>
                        <dd class="col-7 text-break">
                            @Settings.Runtime.ContentRootPath
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </section>

    <section class="card border-0 shadow-sm rounded-4 mt-4">
        <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">@L["ConfigurationNotes"]</h2>

            <ul class="text-secondary small lh-lg mb-0">
                <li>
                    @L["SettingsReadOnlyNote"]
                </li>
                <li>
                    @L["SettingsConfigSourceNote"]
                </li>
                <li>
                    @L["OpenAiApiKeyUserSecretsNote"]
                </li>
                <li>
                    @L["ProductionFileStorageNote"]
                </li>
            </ul>
        </div>
    </section>
}
